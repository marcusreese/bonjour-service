{
    "compilerOptions": {
      "target": "es6",
      "module": "node16",
      "declaration": true,
      "sourceMap": true,
      "outDir": "./dist",
      "strict": true,
      "moduleResolution": "node16",
      "baseUrl": ".",
      "allowSyntheticDefaultImports": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,
      "types": [
        "node"
      ]
    }
  }
  